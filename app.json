{
  "expo": {
    "name": "Expense Test",
    "slug": "expense-test",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "expense-test",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/iconginie.png",
    "splash": {
      "image": "./assets/iconginie.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tatarealty.expense.test",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "This app needs camera access to capture expense bills and to share video in the chat.",
        "NSMicrophoneUsageDescription": "This app needs microphone access for voice input in the chat.",
        "NSPhotoLibraryUsageDescription": "This app needs photo library access to upload expense bills",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSExceptionDomains": {
            "147.93.103.97": {
              "NSExceptionAllowsInsecureHTTPLoads": true,
              "NSIncludesSubdomains": true,
              "NSExceptionMinimumTLSVersion": "TLSv1.0",
              "NSExceptionRequiresForwardSecrecy": false
            }
          }
        }
      },
      "appleTeamId": "MS6YT75Q89"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.tatarealty.expense",
      "adaptiveIcon": {
        "foregroundImage": "./assets/iconginie.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen",
      "expo-font",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1",
            "newArchEnabled": true
          },
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "809a9232-328b-46c4-b2ea-cce57bbb8173"
      }
    },
    "owner": "deeprwt"
  }
}
